{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Engram",
  "version": "0.1.0",
  "identifier": "dev.tuxclaw.engram",
  "build": {
    "devUrl": "http://localhost:3460",
    "frontendDist": "../frontend"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3460 ws://localhost:3460; connect-src 'self' http://localhost:3460 ws://localhost:3460;"
    },
    "windows": [
      {
        "label": "main",
        "title": "Engram — Memory Dashboard",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
